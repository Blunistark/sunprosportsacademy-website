# ═══════════════════════════════════════════════════
#  Christalin Mirrors — .gitignore
# ═══════════════════════════════════════════════════

# Dependencies
node_modules/

# Build output
dist/
build/
.output/

# TypeScript build info
*.tsbuildinfo

# Environment files
.env
.env.*
.env.local
.env.*.local

# OS files
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Package lock (optional — keep if you want reproducible builds)
# package-lock.json

# Excluded project folders
New_images/
pdf_images/
PDFs/
Video ref/

# Docker (not needed in remote for now)
.dockerignore

# Misc
*.tgz
.cache/
.parcel-cache/

# Agent and AI folders
.agents/
.gemini/
skills/

