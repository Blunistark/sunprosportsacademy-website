generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
//  Enums
// ═══════════════════════════════════════════════════════════

enum ServiceCategory {
  HAIR
  SKIN
  KOREAN
  WOMENS
  MENS
}

enum StaffRole {
  STYLIST
  THERAPIST
  MANAGER
  RECEPTIONIST
}

enum UserRole {
  OWNER
  MANAGER
  RECEPTIONIST
}

enum Gender {
  FEMALE
  MALE
  OTHER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  OTHER
}

enum InventoryCategory {
  HAIRCARE
  SKINCARE
  COLOR
  TOOLS
  CONSUMABLES
}

// ═══════════════════════════════════════════════════════════
//  Models
// ═══════════════════════════════════════════════════════════

model Branch {
  id          String   @id @default(cuid())
  name        String   @unique
  city        String
  address     String
  phone       String
  isActive    Boolean  @default(true)
  isComingSoon Boolean @default(false)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff          Staff[]
  appointments   Appointment[]
  invoices       Invoice[]
  inventoryItems InventoryItem[]
  serviceBranches ServiceBranch[]
  clients        Client[]
}

model Service {
  id          String          @id @default(cuid())
  name        String          @unique
  category    ServiceCategory
  duration    Int             // minutes
  price       Int             // paisa
  isActive    Boolean         @default(true)
  isKorean    Boolean         @default(false)
  isFeatured  Boolean         @default(false)
  badge       String?
  description String
  imageUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  serviceBranches ServiceBranch[]
  invoiceItems    InvoiceItem[]
  appointments    Appointment[]
}

model ServiceBranch {
  id            String  @id @default(cuid())
  serviceId     String
  branchId      String
  priceOverride Int?    // paisa

  service Service @relation(fields: [serviceId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([serviceId, branchId])
}

model Staff {
  id          String    @id @default(cuid())
  name        String
  role        StaffRole
  branchId    String
  phone       String
  email       String    @unique
  specialties String[]
  isActive    Boolean   @default(true)
  joinedDate  DateTime
  avatarUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user         User?
  branch       Branch        @relation(fields: [branchId], references: [id])
  appointments Appointment[]
  invoices     Invoice[]
  serviceVisits ServiceVisit[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole
  staffId      String    @unique
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  refreshToken String?   // stored hashed
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  staff Staff @relation(fields: [staffId], references: [id])
}

model Client {
  id               String    @id @default(cuid())
  name             String
  email            String
  phone            String
  gender           Gender
  branchId         String
  joinedDate       DateTime
  totalVisits      Int       @default(0)
  lastVisit        DateTime?
  preferredStaffId String?
  notes            String?
  tags             String[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  branch        Branch        @relation(fields: [branchId], references: [id])
  appointments  Appointment[]
  invoices      Invoice[]
  serviceVisits ServiceVisit[]
}

model Appointment {
  id          String            @id @default(cuid())
  clientId    String?
  clientName  String
  clientEmail String
  clientPhone String?
  date        DateTime          @db.Date
  time        String
  serviceId   String?
  serviceName String
  staffId     String?
  staffName   String?
  status      AppointmentStatus @default(PENDING)
  notes       String?
  branchId    String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  client  Client?  @relation(fields: [clientId], references: [id])
  branch  Branch   @relation(fields: [branchId], references: [id])
  staff   Staff?   @relation(fields: [staffId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id])
  invoice Invoice?
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  clientId        String?
  clientName      String
  clientEmail     String
  clientPhone     String?
  date            DateTime      @db.Date
  subtotal        Int           // paisa
  discountPercent Decimal       @default(0)
  discountAmount  Int           @default(0) // paisa
  taxPercent      Decimal       @default(18)
  taxAmount       Int           @default(0) // paisa
  total           Int           // paisa
  amountPaid      Int           @default(0) // paisa
  status          InvoiceStatus @default(DRAFT)
  paymentMethod   PaymentMethod?
  branchId        String
  staffId         String?
  staffName       String?
  appointmentId   String?       @unique
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client      Client?       @relation(fields: [clientId], references: [id])
  branch      Branch        @relation(fields: [branchId], references: [id])
  staff       Staff?        @relation(fields: [staffId], references: [id])
  appointment Appointment?  @relation(fields: [appointmentId], references: [id])
  items       InvoiceItem[]
  serviceVisit ServiceVisit?
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  serviceId   String?
  serviceName String
  description String?
  quantity    Int
  unitPrice   Int     // paisa
  total       Int     // paisa
  productId   String?

  invoice   Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service   Service?       @relation(fields: [serviceId], references: [id])
  product   InventoryItem? @relation(fields: [productId], references: [id])
}

model ServiceVisit {
  id            String        @id @default(cuid())
  clientId      String
  clientName    String
  date          DateTime      @db.Date
  staffId       String
  staffName     String
  branchId      String
  subtotal      Int           // paisa
  discount      Int           // paisa
  tax           Int           // paisa
  total         Int           // paisa
  paymentMethod PaymentMethod
  notes         String?
  rating        Int?          // 1–5
  invoiceId     String?       @unique
  services      Json          // [{ name, price }]
  createdAt     DateTime      @default(now())

  client  Client   @relation(fields: [clientId], references: [id])
  staff   Staff    @relation(fields: [staffId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])
}

model InventoryItem {
  id            String            @id @default(cuid())
  name          String
  brand         String
  category      InventoryCategory
  sku           String            @unique
  currentStock  Int
  minStock      Int               @default(3)
  costPrice     Int               // paisa
  retailPrice   Int               @default(0) // paisa
  branchId      String
  lastRestocked DateTime?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  branch       Branch        @relation(fields: [branchId], references: [id])
  invoiceItems InvoiceItem[]
}

model SalonSettings {
  id        String   @id @default("singleton")
  name      String
  email     String
  phone     String
  hours     String
  instagram String?
  facebook  String?
  website   String?
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model InvoiceSequence {
  id      String @id @default("singleton")
  lastNum Int    @default(0)
}
